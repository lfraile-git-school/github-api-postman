		{
			"name": "[GraphQL] Get Issues",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{installation-token}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [],
				"body": {
					"mode": "graphql",
					"graphql": {
						"query": "query FindRepo {\r\n    repository(owner: \"lfraileorg\", name: \"NETCore_CI_CD\") {\r\n        issues(first: 5){\r\n                nodes{\r\n                title\r\n                id\r\n                \r\n            }\r\n            pageInfo{\r\n                startCursor\r\n                endCursor\r\n                hasNextPage\r\n                hasPreviousPage\r\n            }\r\n        }        \r\n    }\r\n\t\r\n}",
						"variables": ""
					}
				},
				"url": {
					"raw": "{{api-url}}/graphql",
					"host": [
						"{{api-url}}"
					],
					"path": [
						"graphql"
					]
				}
			},
			"response": []
		},
		{
			"name": "[GraphQL] Get repos",
			"request": {
				"auth": {
					"type": "bearer",
