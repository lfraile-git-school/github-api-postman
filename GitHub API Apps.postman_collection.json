				"method": "POST",
				"header": [],
				"body": {
					"mode": "graphql",
					"graphql": {
						"query": "mutation($input: UpdateRepositoryInput!) {\r\n  updateRepository(input: $input) {\r\n    clientMutationId\r\n    repository {\r\n      name\r\n    }\r\n  }\r\n}\r\n\r\n",
						"variables": "{\r\n\t\"input\": {\r\n\t\t\"repositoryId\": \"R_kgDOJKXnlg\",\r\n\t\t\"name\": \"Test from graphQL prisa\"\r\n\t}\r\n}\r\n\r\n"
					}
				},
				"url": {
					"raw": "{{api-url}}/graphql",
					"host": [
						"{{api-url}}"
					],
					"path": [
						"graphql"
					]
				}
			},
			"response": []
		},
		{
			"name": "[GraphQL] Costly query",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{installation-token}}",
							"type": "string"
